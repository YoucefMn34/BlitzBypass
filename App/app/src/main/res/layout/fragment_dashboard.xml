<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:background="?android:attr/colorBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingTop="32dp">

            <!-- Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="8dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:paddingTop="28dp"
                    android:paddingBottom="24dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:background="@drawable/status_card_bg">

                    <!-- Battery Icon -->
                    <com.youcefm.bypassctrl.BatteryIconView
                        android:id="@+id/batteryIcon"
                        android:layout_width="60dp"
                        android:layout_height="84dp"
                        android:layout_marginBottom="8dp" />

                    <!-- Mode Text -->
                    <TextView
                        android:id="@+id/tvMode"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CHARGE"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="4dp" />

                    <!-- Status Label -->
                    <TextView
                        android:id="@+id/tvStatusLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="mode active"
                        android:textSize="13sp"
                        android:textColor="#80FFFFFF"
                        android:layout_marginBottom="20dp" />

                    <!-- Toggle Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToggle"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:paddingStart="24dp"
                        android:paddingEnd="24dp"
                        android:minWidth="140dp"
                        app:cornerRadius="22dp"
                        app:icon="@drawable/ic_power"
                        app:iconSize="18dp"
                        app:iconGravity="textStart"
                        app:iconPadding="8dp"
                        android:text="Toggle"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:letterSpacing="0.03"
                        app:backgroundTint="@android:color/transparent"
                        app:strokeColor="#D0BCFF"
                        app:strokeWidth="2dp"
                        android:textColor="#D0BCFF" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Power Flow -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/premium_card_bg">

                    <com.youcefm.bypassctrl.PowerFlowView
                        android:id="@+id/powerFlow"
                        android:layout_width="match_parent"
                        android:layout_height="44dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Charging Info Grid -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:background="@drawable/premium_card_bg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Charging Info"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginBottom="16dp" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:useDefaultMargins="true">

                        <!-- Battery Level -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:layout_marginBottom="16dp"
                            android:padding="12dp"
                            android:background="@drawable/premium_card_bg">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">

                                <View
                                    android:layout_width="6dp"
                                    android:layout_height="6dp"
                                    android:background="@drawable/circle_indicator"
                                    android:backgroundTint="@color/indicator_battery" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Level"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    android:layout_marginStart="6dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvLevel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/indicator_battery" />
                        </LinearLayout>

                        <!-- Status -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:layout_marginBottom="16dp"
                            android:padding="12dp"
                            android:background="@drawable/premium_card_bg">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">

                                <View
                                    android:layout_width="6dp"
                                    android:layout_height="6dp"
                                    android:background="@drawable/circle_indicator"
                                    android:backgroundTint="@color/indicator_status" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Status"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    android:layout_marginStart="6dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/indicator_status" />
                        </LinearLayout>

                        <!-- Temperature -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:layout_marginBottom="16dp"
                            android:padding="12dp"
                            android:background="@drawable/premium_card_bg">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">

                                <View
                                    android:layout_width="6dp"
                                    android:layout_height="6dp"
                                    android:background="@drawable/circle_indicator"
                                    android:backgroundTint="@color/indicator_temp" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Temp"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    android:layout_marginStart="6dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvTemp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/indicator_temp" />
                        </LinearLayout>

                        <!-- Voltage -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:layout_marginBottom="16dp"
                            android:padding="12dp"
                            android:background="@drawable/premium_card_bg">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">

                                <View
                                    android:layout_width="6dp"
                                    android:layout_height="6dp"
                                    android:background="@drawable/circle_indicator"
                                    android:backgroundTint="@color/indicator_voltage" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Voltage"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    android:layout_marginStart="6dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvVoltage"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/indicator_voltage" />
                        </LinearLayout>

                        <!-- Current -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:layout_marginBottom="8dp"
                            android:padding="12dp"
                            android:background="@drawable/premium_card_bg">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">

                                <View
                                    android:layout_width="6dp"
                                    android:layout_height="6dp"
                                    android:background="@drawable/circle_indicator"
                                    android:backgroundTint="@color/indicator_current" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Current"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    android:layout_marginStart="6dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvCurrent"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/indicator_current" />
                        </LinearLayout>

                        <!-- Power -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:layout_marginBottom="8dp"
                            android:padding="12dp"
                            android:background="@drawable/premium_card_bg">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:layout_marginBottom="4dp">

                                <View
                                    android:layout_width="6dp"
                                    android:layout_height="6dp"
                                    android:background="@drawable/circle_indicator"
                                    android:backgroundTint="@color/indicator_power" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Power"
                                    android:textSize="11sp"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    android:layout_marginStart="6dp" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvPower"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="@color/indicator_power" />
                        </LinearLayout>

                        <!-- Charge Current (full width) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_columnSpan="2"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:padding="12dp"
                            android:background="@drawable/premium_card_bg">

                            <View
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/circle_indicator"
                                android:backgroundTint="@color/indicator_cc" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Charge Current"
                                android:textSize="12sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginStart="10dp" />

                            <TextView
                                android:id="@+id/tvCC"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/indicator_cc" />
                        </LinearLayout>

                    </GridLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
